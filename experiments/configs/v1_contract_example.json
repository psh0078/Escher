{
  "simulation_metadata": {
    "name": "v1-contract-smoke",
    "duration": 120.0,
    "seed": 42,
    "time_unit": "second"
  },
  "services": [
    {
      "name": "gateway",
      "instances": 1,
      "operations": [
        {
          "name": "GET",
          "dependencies": [
            {
              "service": "service1",
              "operation": "calc",
              "failure_probability": 0.1,
              "latency": 0.15
            }
          ]
        }
      ]
    },
    {
      "name": "service1",
      "instances": 2,
      "operations": [
        {
          "name": "calc",
          "dependencies": [
            {
              "service": "service2",
              "operation": "db_lookup",
              "failure_probability": 0.02,
              "latency": 0.05
            }
          ]
        }
      ]
    },
    {
      "name": "service2",
      "instances": 1,
      "operations": [
        {
          "name": "db_lookup",
          "dependencies": []
        }
      ]
    }
  ],
  "workloads": [
    {
      "type": "constant_rate",
      "target": "gateway.GET",
      "interval": 0.5
    }
  ],
  "faultloads": [
    {
      "type": "delay_injection",
      "target": "service1.calc",
      "start": 40.0,
      "end": 55.0,
      "latency": 0.2
    },
    {
      "type": "kill_instance",
      "target_service": "service1",
      "instance_count": 1,
      "at": 60.0
    }
  ],
  "policies": {
    "retry": {
      "max_attempts": 3,
      "base_backoff": 0.1,
      "multiplier": 2.0,
      "max_backoff": 2.0
    },
    "circuit_breaker": {
      "failure_threshold": 0.5,
      "rolling_window": 10.0,
      "min_calls": 12,
      "open_timeout": 3.0
    },
    "connection_limiter": {
      "max_inflight": 100
    }
  }
}
